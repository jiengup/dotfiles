{
  "C_Cpp.intelliSenseEngine": "disabled",
  "clangd.arguments": [
    "--header-insertion=never",
    "--query-driver=/opt/compiler/gcc-12/bin/g++",
    "--all-scopes-completion",
    "--inlay-hints",
    "--completion-style=detailed",
    "--j=8",
    "--pch-storage=disk",
    "--compile-commands-dir=build",
    "--background-index",
    "--log=error"
  ],
  "C_Cpp.clang_format_style": "file:/ssd2/xingguangjie1/.config/clang-format/.clang-format",
  "C_Cpp.formatting": "clangFormat",
  "files.trimFinalNewlines": true,
  "files.insertFinalNewline": true,
  "editor.accessibilitySupport": "off",
  "editor.fontFamily": "'SauceCodePro Nerd Font Mono', monospace",
  "editor.fontSize": 16,
  "editor.inlineSuggest.enabled": true,
  "editor.largeFileOptimizations": false,
  "editor.minimap.autohide": "mouseover",
  "editor.peekWidgetDefaultFocus": "editor",
  "editor.cursorBlinking": "smooth",
  "editor.cursorSurroundingLines": 2,
  "editor.mouseWheelScrollSensitivity": 1,
  "editor.fastScrollSensitivity": 3,
  "editor.smoothScrolling": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.suggest.preview": true,
  "editor.suggestSelection": "first",
  "explorer.autoReveal": true,
  "explorer.confirmDragAndDrop": false,
  "git.openRepositoryInParentFolders": "never",
  "git.suggestSmartCommit": false,
  "notebook.lineNumbers": "on",
  "notebook.output.textLineLimit": 500,
  "remote.SSH.defaultExtensions": [
    "llvm-vs-code-extensions.vscode-clangd",
  ],
  "security.workspace.trust.untrustedFiles": "open",
  "vim.autoSwitchInputMethod.enable": true,
  "vim.camelCaseMotion.enable": true,
  "vim.digraphs": {},
  "vim.easymotion": true,
  "vim.foldfix": true,
  "vim.handleKeys": {
    "<C-a>": true,
    "<C-b>": true,
    "<C-d>": false,
    "<C-f>": true,
    "<C-i>": true,
    "<C-o>": true,
    "<C-r>": true,
    "<C-s>": false,
    "<C-t>": false,
    "<C-v>": true,
    "<C-w>": true,
    "<C-h>": false,
    "<C-j>": false,
    "<C-k>": false,
    "<C-l>": false,
  },
  "vim.history": 10000,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.leader": ";",
  "vim.normalModeKeyBindings": [
    {
      "after": [],
      "before": [
        "u"
      ],
      "commands": [
        {
          "command": "undo"
        }
      ]
    },
    {
      "after": [],
      "before": [
        "<C-r>"
      ],
      "commands": [
        {
          "command": "redo"
        }
      ]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
    "before": ["<C-a>", "h"],
    "commands": ["workbench.action.focusLeftGroup"]
    },
    {
      "before": ["<C-a>", "l"],
      "commands": ["workbench.action.focusRightGroup"]
    },
    {
      "before": ["<C-a>", "j"],
      "commands": ["workbench.action.focusBelowGroup"]
    },
    {
      "before": ["<C-a>", "k"],
      "commands": ["workbench.action.focusAboveGroup"]
    },
    {
      "before": ["<C-a>", "z"],
      "commands": ["workbench.action.toggleMaximizeEditorGroup"]
    },
    {
      "before": [
        "s",
        "i",
        "w"
      ],
      "commands": [
        "editor.action.addSelectionToNextFindMatch", // 相当于选中当前单词
        {
          "command": "workbench.action.findInFiles",
          "args": {
            "query": "${selectedText}",
            "triggerSearch": true
          }
        }
      ]
    },
    {
      "before": [
        "<leader>",
        "f"
      ],
      "commands": [
        "editor.action.formatDocument"
      ]
    },
    {
      "before": [
        "<leader>",
        "U"
      ],
      "commands": [
        "references-view.findReferences"
      ]
    },
    {
      "before": [
        "<leader>",
        "d",
        "r"
      ],
      "commands": [
        "workbench.action.files.save",
        "workbench.action.debug.start"
      ]
    },
    {
      "before": [
        "<leader>",
        "d",
        "b"
      ],
      "commands": [
        "editor.debug.action.toggleBreakpoint"
      ]
    },
    {
      "before": [
        "<leader>",
        "d",
        "c"
      ],
      "commands": [
        "editor.debug.action.conditionalBreakpoint"
      ]
    }
  ],
  "vim.surround": true,
  "vim.useCtrlKeys": false,
  "vim.useSystemClipboard": true,
  "vim.vimrc.path": "$HOME/.vimrc",
  "vim.visualModeKeyBindings": [
    {
      "before": [
        ">"
      ],
      "commands": [
        "editor.action.indentLines"
      ]
    },
    {
      "before": [
        "<"
      ],
      "commands": [
        "editor.action.outdentLines"
      ]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<leader>",
        "f"
      ],
      "commands": [
        "editor.action.formatSelection"
      ]
    },
    {
      "after": [
        "p",
        "g",
        "v",
        "y"
      ],
      "before": [
        "p"
      ]
    },
    {
      "before": [
        ">"
      ],
      "commands": [
        "editor.action.indentLines"
      ]
    },
    {
      "before": [
        "<"
      ],
      "commands": [
        "editor.action.outdentLines"
      ]
    }
  ],
  /* vim settings end */
  "window.autoDetectColorScheme": true,
  "window.commandCenter": false,
  "workbench.layoutControl.enabled": false,
  "workbench.list.smoothScrolling": true,
  "workbench.preferredLightColorTheme": "Aura Soft Dark",
  "workbench.preferredDarkColorTheme": "One Dark Pro Night Flat",
  "baidu.comate.superCompletion": {
    "superCompletion": true,
    "autoImport": false
  },
  "baidu.comate.completionLength": "auto",
  "editor.formatOnSave": false,
  "baidu.comate.enableCodelens": {
    "enableInlineUnitTest": false,
    "enableInlineExplain": false,
    "enableInlineDocstring": false,
    "enableInlineSplit": false,
    "enableInlineComment": false,
    "enableInlineOptimize": false,
  },
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.fontFamily": "SauceCodePro Nerd Font Mono, Menlo, Monaco",
  "terminal.integrated.fontSize": 14,
  "terminal.explorerKind": "external",
  "terminal.external.osxExec": "iTerm2.app",
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
          "comment",
          "keyword",
          "storage",
        ],
        "settings": {
          "fontStyle": "italic"
        }
      }
    ]
  },
  "workbench.activityBar.location": "top",
  "workbench.activityBar.iconClickBehavior": "toggle",
  "claudeCode.preferredLocation": "sidebar",
  "baidu.comate.joinLab": true,
  "terminal.integrated.scrollback": 10000,
  "workbench.iconTheme": "material-icon-theme",
  "window.customTitleBarVisibility": "windowed",
  "remote.downloadExtensionsLocally": true,
  "baidu.comate.username": "xingguangjie",
  "window.density.editorTabHeight": "compact",
  "remote.autoForwardPortsSource": "hybrid",
  "diffEditor.ignoreTrimWhitespace": false,
}
